{
  "name": "intent-poc",
  "version": "0.1.0",
  "private": true,
  "description": "Intent-driven visual evidence proof of concept controller.",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test:changed": "tsx src/orchestrator/test-impact-detector.ts",
    "test:code": "tsx src/test/run-code-tests.ts",
    "test:code:all": "tsx --test src/**/*.test.ts",
    "test:update-demo-library": "tsx src/demo-app/generate-demo-library.ts --skip-preflight",
    "test:stack": "npm run test:code:all && npm run test:update-demo-library",
    "test": "npm run test:stack",
    "demo:serve": "tsx src/cli.ts demo",
    "demo:library": "tsx src/demo-app/generate-demo-library.ts",
    "start": "node dist/cli.js",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@google/genai": "^1.50.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.51.1",
    "pngjs": "^7.0.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pngjs": "^6.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
